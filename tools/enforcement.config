# MANAGED FILE - Updates pulled from template. See MANAGED_FILES.md
# Per-check enforcement defaults for run_checks.sh and CI workflows.
# Set to "true" to make a check blocking, "false" to make it advisory.
# See README.md "Checks and enforcement" for details.
#
# This file is bash-sourceable: each line is `KEY=value` with no spaces
# around the `=`. Lines starting with `#` and blank lines are ignored.

# Default-enforced (correctness) — flip to false to make advisory.
ENFORCE_RUFF=true
ENFORCE_MYPY=true
ENFORCE_POSIX_CHECK=true
ENFORCE_UV_LOCK=true
ENFORCE_UNLISTED_EVALS=true
# Advisory for now: chipbench's debug/{zero,one}_shot_* dirs duplicate
# ref.sv/test.sv across shot variants, tripping the wheel-build W002
# duplicate-file check. Revisit once the debug data layout is finalized.
ENFORCE_PACKAGE=false

# Default-advisory (structure / style) — flip to true to make blocking.
ENFORCE_AUTOLINT=false
ENFORCE_GENERATED_DOCS=false
ENFORCE_MARKDOWN_LINT=false
ENFORCE_LARGE_FILES=false
ENFORCE_PR_TEMPLATE=false
